{
  "name": "cashflow-architecture-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "Arquitetura de fluxo de caixa diário com NestJS, Clean Architecture e separação de domínios.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:ledger": "node dist/apps/ledger-service/src/main.js",
    "start:daily-balance": "node dist/apps/daily-balance-service/src/main.js",
    "dev:ledger": "tsx watch apps/ledger-service/src/main.ts",
    "dev:daily-balance": "tsx watch apps/daily-balance-service/src/main.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand",
    "test:load:info": "node test/load/README.js"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.888.0",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
